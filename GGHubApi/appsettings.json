{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=YOUR_SERVER;Initial Catalog=GGHubDB;Integrated Security=True;Connect Timeout=30;Encrypt=True;Trust Server Certificate=True;Application Intent=ReadWrite;Multi Subnet Failover=False"
  },
  "DatHost": {
    "BaseUrl": "https://dathost.net/api/0.1/",
    "Email": "your-dathost-email@example.com",
    "Password": "YOUR_DATHOST_PASSWORD",
    "AccountEmail": "your-dathost-email@example.com",
    "TimeoutSeconds": 30,
    "MaxRetryAttempts": 3,
    "RetryDelayMs": 1000,
    "WebhookUrl": "https://your-domain.com/api/webhook/dathost",
    "WebhookSecret": "YOUR_WEBHOOK_SECRET"
  },
  "Cryptomus": {
    "WebhookIP": "91.227.144.54",
    "MerchantId": "YOUR_CRYPTOMUS_MERCHANT_ID",
    "PaymentKey": "YOUR_CRYPTOMUS_PAYMENT_KEY"
  },
  "Steam": {
    "ApiKey": "YOUR_STEAM_API_KEY",
    "LoginUrl": "https://steamcommunity.com/openid/login",
    "CallbackPath": "/auth/steam/callback"
  },
  "Jwt": {
    "Issuer": "GGHub",
    "Audience": "GGHubClients",
    "SecretKey": "YOUR_JWT_SECRET_KEY_MIN_32_CHARS_HERE",
    "ExpirationDays": 60
  },
  "RateLimiting": {
    "AuthEndpoints": {
      "PermitLimit": 5,
      "WindowMinutes": 1
    }
  },
  "BotAccount": {
    "Email": "GGHubBot@test.com",
    "Username": "Bot",
    "Password": "YOUR_BOT_PASSWORD"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://your-domain.com",
      "https://www.your-domain.com",
      "http://localhost:3000",
      "http://localhost:5173",
      "https://steamcommunity.com"
    ]
  },
  "App": {
    "PublicBaseUrl": "https://your-domain.com/"
  }
}
